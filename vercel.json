{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "env": {
    "DEMO_DAY_ALLOW_EPHEMERAL_STORAGE": "true"
  },
  "rewrites": [
    {
      "source": "/:path((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/models/green-circuit-board-:variant.glb",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
